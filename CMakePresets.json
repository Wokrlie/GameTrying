    "buildPresets": [
        {
            "name": "ninja-debug",
            "configurePreset": "linux-ninja-debug",
            "displayName": "Build with Ninja (Debug)",
            "description": "使用 Ninja 构建 Debug 版本"
        },
        {
            "name": "ninja-release",
