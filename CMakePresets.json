            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_STANDARD": "17",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF"
            },
            "environment": {
                "CC": "gcc",
                "CXX": "g++"
            }
        },
        {
            "name": "linux-make-debug",
            "displayName": "Linux Unix Makefiles Debug",
            "description": "使用 Unix Makefiles 生成器，Debug 构建",
